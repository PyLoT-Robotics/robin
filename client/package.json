{
  "name": "robin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun showQRcode.ts && vp dev --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vp preview",
    "test:unit": "vp test",
    "build-only": "vp build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
